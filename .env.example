# WordPress read source
WP_BASE_URL=https://example.com
WP_USERNAME=
WP_APPLICATION_PASSWORD=
WP_TIMEOUT_SECONDS=20

# Google Search Console
# OAuth scope: https://www.googleapis.com/auth/webmasters.readonly
# Short-lived access token. Leave empty when using GOOGLE_REFRESH_TOKEN.
GSC_ACCESS_TOKEN=
GSC_SITE_URL=https://example.com/

# Google Analytics 4
# OAuth scope: https://www.googleapis.com/auth/analytics.readonly
# Short-lived access token. Leave empty when using GOOGLE_REFRESH_TOKEN.
GA4_ACCESS_TOKEN=
GA4_PROPERTY_ID=

# Google OAuth long-lived credentials
# Recommended for OpenCrawl/MCP usage. The server refreshes access tokens automatically.
# Required OAuth scopes:
# - https://www.googleapis.com/auth/webmasters.readonly
# - https://www.googleapis.com/auth/analytics.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# MCP server
LOG_LEVEL=INFO

# MCP HTTP server for always-on Web UI / Hermes Agent connections
MCP_HTTP_HOST=localhost
MCP_HTTP_PORT=8765
# Optional bearer token. If set, clients must send: Authorization: Bearer <token>
MCP_HTTP_TOKEN=
# Optional CORS origin, for example http://<LAN_HOST>:3000
MCP_ALLOWED_ORIGIN=
